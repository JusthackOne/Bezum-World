NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
APP_TIME_ZONE=Europe/Moscow
APP_DOMAIN=http://localhost

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/social_rpg?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

QUEUE_DEFAULT_NAME=default

AUTH_JWT_ACCESS_SECRET=replace-with-long-access-secret
AUTH_JWT_REFRESH_SECRET=replace-with-long-refresh-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change-this-admin-password

SEED_ENV=test
