{
  "name": "social-rpg-backend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "description": "NestJS backend blueprint for Social RPG",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "bunx --bun tsc -p tsconfig.build.json",
    "start": "bun dist/main.js",
    "start:dev": "bunx --bun nest start --watch",
    "start:prod": "bun dist/main.js",
    "lint": "bunx --bun eslint .",
    "lint:fix": "bunx --bun eslint . --fix",
    "format": "bunx --bun prettier --write .",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev",
    "prisma:studio": "bunx --bun prisma studio",
    "prisma:seed": "bun run prisma/seed.ts"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "^11.2.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "7.7.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "5.73.4",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "5.10.1",
    "nestjs-pino": "4.6.1",
    "pg": "^8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.19",
    "@nestjs/schematics": "11.0.10",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "dotenv": "17.4.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.2",
    "prisma": "7.7.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  }
}
