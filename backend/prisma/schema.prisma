generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id               String    @id @default(uuid())
  username         String
  avatarUrl        String?
  strength         Int       @default(0)
  charisma         Int       @default(0)
  endurance        Int       @default(0)
  intelligence     Int       @default(0)
  lastTimeLoggedIn DateTime?
  createdAt        DateTime  @default(now())
  authCode         AuthCode?
  items            Item[]
}

model AuthCode {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(6)
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Admin {
  id               String    @id @default(uuid())
  singletonKey     String    @unique @default("singleton")
  username         String    @unique
  passwordHash     String
  lastTimeLoggedIn DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

enum ItemRarity {
  unterlyanskiy
  basic_minimum
  sigma
  bezumnyy
}

model Item {
  id           String      @id @default(uuid())
  ownerUserId  String?     @map("owner_user_id")
  owner        Account?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  name         String
  description  String?
  imageUrl     String?     @map("image_url")
  strength     Int?
  charisma     Int?
  agility      Int?
  intelligence Int?
  price        Int
  rarity       ItemRarity
  durability   Int?
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([ownerUserId])
  @@map("items")
}
