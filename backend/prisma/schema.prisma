generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EquipmentSlotType {
  HELMET
  ARMOR
  PANTS
  BOOTS
  LEFT_HAND
  RIGHT_HAND
}

model Account {
  id               String    @id @default(uuid())
  username         String    @unique
  avatarUrl        String?
  balance          Int       @default(0)
  gameScore        Int       @default(0)
  strength         Int       @default(0)
  charisma         Int       @default(0)
  endurance        Int       @default(0)
  intelligence     Int       @default(0)
  lastTimeLoggedIn DateTime?
  createdAt        DateTime  @default(now())
  authCode         AuthCode?
  items            Item[]
  equipment        UserEquipmentSlot[]
  taskSubmissions  TaskSubmission[]
}

model AuthCode {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(6)
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Admin {
  id               String    @id @default(uuid())
  singletonKey     String    @unique @default("singleton")
  username         String    @unique
  passwordHash     String
  lastTimeLoggedIn DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

enum ItemRarity {
  unterlyanskiy
  basic_minimum
  sigma
  bezumnyy
}

model Item {
  id           String      @id @default(uuid())
  ownerUserId  String?     @map("owner_user_id")
  owner        Account?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  name         String
  description  String?
  imageUrl     String?     @map("image_url")
  strength     Int?
  charisma     Int?
  agility      Int?
  intelligence Int?
  price        Int
  rarity       ItemRarity
  durability   Int?

  slotType  EquipmentSlotType
  equippedSlot UserEquipmentSlot?
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([ownerUserId])
  @@map("items")
}

model UserEquipmentSlot {
  id        String               @id @default(cuid())

  userId    String
  user      Account                 @relation(fields: [userId], references: [id])

  slotType  EquipmentSlotType

  itemId    String?              @unique
  item      Item?                @relation(fields: [itemId], references: [id])

  @@unique([userId, slotType])
}

enum TaskType {
  daily
  weekly
  event
}

model Task {
  id                 String           @id @default(uuid())
  type               TaskType
  title              String
  description        String?
  image              String?
  rewardMoney        Int              @map("reward_money")
  rewardGameScore    Int?             @map("reward_game_score")
  rewardAttributes   Json?            @map("reward_attributes")
  requiresProofImage Boolean          @default(false) @map("requires_proof_image")
  submissionLimit    Int?             @map("submission_limit")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  submissions        TaskSubmission[]

  @@index([type])
  @@index([createdAt])
  @@map("tasks")
}

model TaskSubmission {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  userId     String   @map("user_id")
  proofImage String?  @map("proof_image")
  createdAt  DateTime @default(now()) @map("created_at")

  task Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([taskId, userId, createdAt])
  @@map("task_submissions")
}
